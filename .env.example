# Agentronics landing page

# Clerk — same instance/keys as the dashboard so the session is shared.
# Without these, the site builds and runs but Login/Sign up pages won't work.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Where to send users after they sign in / sign up (the dashboard app).
# For shared-session SSO this must be a subdomain of the same root domain as
# this site (e.g. https://app.agentronics.dev).
NEXT_PUBLIC_DASHBOARD_URL=https://dashboard-dashboard-nu.vercel.app/overview
